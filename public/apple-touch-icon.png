<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 180">
  <!-- Wood background gradient -->
  <defs>
    <linearGradient id="woodGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f9f3ed;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f5ede4;stop-opacity:1" />
    </linearGradient>
  </defs>

  <rect width="180" height="180" fill="url(#woodGrad)" rx="40"/>

  <!-- Dice with shadow -->
  <g transform="translate(90, 90)">
    <!-- Shadow -->
    <rect x="-55" y="-53" width="110" height="110" rx="15" fill="#00000020"/>

    <!-- Main dice body -->
    <rect x="-58" y="-58" width="116" height="116" rx="16" fill="#8b7355"/>

    <!-- Dice dots (5 pattern) -->
    <circle cx="-25" cy="-25" r="9" fill="#f9f3ed"/>
    <circle cx="25" cy="-25" r="9" fill="#f9f3ed"/>
    <circle cx="0" cy="0" r="9" fill="#f9f3ed"/>
    <circle cx="-25" cy="25" r="9" fill="#f9f3ed"/>
    <circle cx="25" cy="25" r="9" fill="#f9f3ed"/>
  </g>
</svg>
