generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Auth.js required models

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Profile customization fields
  username        String? @unique // Public profile URL slug (e.g. /u/username)
  displayName     String? // Custom display name (overrides OAuth name)
  customImageUrl  String? // Custom profile image URL (overrides OAuth image)
  favoriteGenres  String? // Comma-separated genre tags
  isProfilePublic  Boolean @default(true)  // Whether public profile URL is accessible
  featuredEntryIds String?                 // JSON: up to 3 GameEntry IDs shown on business card
  cardTheme        String  @default("amber") // Business card color theme
  role             Role    @default(USER)

  accounts      Account[]
  sessions      Session[]
  gameEntries   GameEntry[]
  wishlistItems WishlistItem[]
  nameReports   NameReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

// Application domain models

model Game {
  id          String  @id @default(cuid())
  bggId       String? @unique // BGG game ID
  name        String
  nameJa      String? // 日本語名（BGG alternate nameより）
  customNameJa String? // ユーザーがカスタムでつけた日本語名（nameJaより優先）
  imageUrl    String?
  categories  String? // BGGカテゴリ（カンマ区切り）例: "Fantasy,Economic"
  mechanics   String? // BGGメカニクス（カンマ区切り）例: "Deck Building,Worker Placement"
  weight      Float?  // BGG複雑度 1.0〜5.0
  playingTime Int?    // 標準プレイ時間（分）
  minPlayers  Int?
  maxPlayers  Int?

  gameEntries   GameEntry[]
  wishlistItems WishlistItem[]
  nameReports   NameReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 気になるリスト
model WishlistItem {
  id     String @id @default(cuid())
  userId String
  gameId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, gameId])
  @@index([userId])
}

// ユーザーとゲームの関係（評価は1ゲームにつき1つ）
model GameEntry {
  id     String @id @default(cuid())
  userId String
  gameId String
  rating Int    // 1-5

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  game     Game          @relation(fields: [gameId], references: [id])
  sessions PlaySession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([userId])
}

// プレイ日ごとの記録（メモ・画像）
model PlaySession {
  id          String   @id @default(cuid())
  gameEntryId String
  playedAt    DateTime?
  memo        String?  @db.Text
  imageUrl    String?

  gameEntry GameEntry @relation(fields: [gameEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameEntryId])
  @@index([playedAt])
}

// ゲーム名の誤り報告
model NameReport {
  id            String       @id @default(cuid())
  gameId        String
  reporterId    String
  suggestedName String       // 提案する日本語名
  reason        String?      @db.Text // 任意コメント
  status        ReportStatus @default(PENDING)
  reviewedById  String?      // 承認・却下したadminのuserId

  game         Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  reporter     User  @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([gameId])
}
